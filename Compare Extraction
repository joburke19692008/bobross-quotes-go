#!/usr/bin/env python3
"""
compare_extraction.py
---------------------
Compare PDF extraction output against the original.
Opens the extracted JSON and displays text page by page for manual review.

Usage:
    python compare_extraction.py output.json
    python compare_extraction.py output.json --page 3
    python compare_extraction.py output.json --summary
"""

import json
import argparse
import sys


def load_extraction(json_path: str) -> dict:
    """Load extraction JSON file."""
    try:
        with open(json_path, 'r', encoding='utf-8') as f:
            return json.load(f)
    except FileNotFoundError:
        print(f"ERROR: File not found: {json_path}")
        sys.exit(1)
    except json.JSONDecodeError:
        print(f"ERROR: Invalid JSON: {json_path}")
        sys.exit(1)


def print_summary(data: dict):
    """Print extraction summary."""
    info = data.get('extraction_info', {})
    summary = data.get('summary', {})
    
    print("=" * 60)
    print("EXTRACTION SUMMARY")
    print("=" * 60)
    print(f"File:            {info.get('source_file', 'N/A')}")
    print(f"Total Pages:     {summary.get('total_pages', 0)}")
    print(f"Total Chars:     {summary.get('total_characters', 0)}")
    print(f"Pages w/ Text:   {summary.get('pages_with_text', 0)}")
    print(f"OCR Pages:       {summary.get('pages_ocr_required', 0)}")
    print(f"Total Images:    {summary.get('total_images', 0)}")
    print("=" * 60)
    print()
    print("PAGE BREAKDOWN:")
    print("-" * 60)
    
    for p in data.get('pages', []):
        status = "✓" if p.get('has_text') else "✗"
        method = p.get('extraction_method', 'unknown')
        chars = p.get('text_length', 0)
        images = len(p.get('images', []))
        print(f"  Page {p['page_number']:3d}: {status} {chars:6d} chars | {method:10s} | {images} images")
    
    print()
    
    # Flag issues
    issues = []
    for p in data.get('pages', []):
        if not p.get('has_text'):
            issues.append(f"Page {p['page_number']}: No text extracted")
        if p.get('extraction_method') == 'ocr_failed':
            issues.append(f"Page {p['page_number']}: OCR failed")
        if p.get('text_length', 0) < 50 and p.get('has_text'):
            issues.append(f"Page {p['page_number']}: Very little text ({p['text_length']} chars)")
    
    if issues:
        print("POTENTIAL ISSUES:")
        for issue in issues:
            print(f"  ⚠ {issue}")
    else:
        print("✓ No issues detected.")


def print_page(data: dict, page_num: int):
    """Print a single page's extracted text."""
    pages = data.get('pages', [])
    
    for p in pages:
        if p['page_number'] == page_num:
            print(f"===== PAGE {page_num} =====")
            print(f"Method: {p.get('extraction_method', 'unknown')}")
            print(f"Characters: {p.get('text_length', 0)}")
            print(f"Images: {len(p.get('images', []))}")
            print("-" * 40)
            print()
            print(p.get('text', ''))
            print()
            return
    
    print(f"ERROR: Page {page_num} not found")


def print_all_pages(data: dict):
    """Print all pages' extracted text."""
    pages = data.get('pages', [])
    
    for p in pages:
        print(f"===== PAGE {p['page_number']} =====")
        print(f"Method: {p.get('extraction_method', 'unknown')} | Chars: {p.get('text_length', 0)}")
        print("-" * 40)
        print(p.get('text', ''))
        print()
        print()


def main():
    parser = argparse.ArgumentParser(description="Compare PDF extraction output")
    parser.add_argument("json_file", help="Path to extraction JSON output")
    parser.add_argument("--page", "-p", type=int, help="Show specific page number")
    parser.add_argument("--summary", "-s", action="store_true", help="Show summary only")
    
    args = parser.parse_args()
    
    data = load_extraction(args.json_file)
    
    if args.summary:
        print_summary(data)
    elif args.page:
        print_page(data, args.page)
    else:
        print_summary(data)
        print("\n")
        print_all_pages(data)


if __name__ == "__main__":
    main()
